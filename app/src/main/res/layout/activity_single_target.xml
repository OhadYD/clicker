<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Single Target Mode"
            android:textColor="?attr/accentMain"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Click interval (ms)"
            android:textColor="@color/textMain"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="300"
            android:textColor="@color/textMain"
            android:textColorHint="@color/textDim" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Action type"
            android:textColor="@color/textMain"
            android:textSize="15sp" />

        <RadioGroup
            android:id="@+id/rgAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbTap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Tap"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbHold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="Hold"
                android:textColor="@color/textMain" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/holdRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hold duration (ms)"
                android:textColor="@color/textMain"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etHold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="800"
                android:textColor="@color/textMain"
                android:textColorHint="@color/textDim" />

            <CheckBox
                android:id="@+id/cbPermanentHold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Permanent hold until Stop"
                android:textColor="@color/textMain" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Stop condition"
            android:textColor="@color/textMain"
            android:textSize="15sp" />

        <RadioGroup
            android:id="@+id/rgStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbInfinite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Run indefinitely"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stop after amount of time"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbCycles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stop after number of cycles"
                android:textColor="@color/textMain" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/timeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Stop after (seconds)"
                android:textColor="@color/textMain"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etStopTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="60"
                android:textColor="@color/textMain"
                android:textColorHint="@color/textDim" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cyclesRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Number of cycles"
                android:textColor="@color/textMain"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etStopCycles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="100"
                android:textColor="@color/textMain"
                android:textColorHint="@color/textDim" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtWarning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="?attr/accentSecondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnLaunch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="?attr/accentMain"
            android:text="Show overlay"
            android:textColor="@color/bg" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/card"
            android:text="Save as configuration"
            android:textColor="@color/textMain" />
    </LinearLayout>
</ScrollView>
