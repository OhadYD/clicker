<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/rowTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Target 1"
            android:textColor="@color/teal"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="↑"
            android:textColor="@color/textMain"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btnDown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="↓"
            android:textColor="@color/textMain"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btnDel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="✕"
            android:textColor="@color/pink"
            android:textSize="18sp" />
    </LinearLayout>

    <Spinner
        android:id="@+id/spType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp" />

    <LinearLayout
        android:id="@+id/holdRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hold (ms):"
            android:textColor="@color/textMain"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etHold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:inputType="number"
            android:text="800"
            android:textColor="@color/textMain"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/swipeRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swipe (ms):"
            android:textColor="@color/textMain"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etSwipe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:inputType="number"
            android:text="300"
            android:textColor="@color/textMain"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delay before:"
            android:textColor="@color/textDim"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etBefore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:inputType="number"
            android:text="0"
            android:textColor="@color/textMain"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="after:"
            android:textColor="@color/textDim"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etAfter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:inputType="number"
            android:text="200"
            android:textColor="@color/textMain"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
