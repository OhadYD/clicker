<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Common Settings"
            android:textColor="?attr/accentMain"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTargetSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Target size: 56 dp"
            android:textColor="@color/textMain"
            android:textSize="15sp" />

        <SeekBar
            android:id="@+id/seekTarget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="96" />

        <TextView
            android:id="@+id/txtBarScale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Control bar size: 100% (applies when overlay is reopened)"
            android:textColor="@color/textMain"
            android:textSize="15sp" />

        <SeekBar
            android:id="@+id/seekBarScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="150" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Vibrate on start / stop"
            android:textColor="@color/textMain"
            android:textSize="15sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchCountdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="3-second countdown before start"
            android:textColor="@color/textMain"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Appearance"
            android:textColor="?attr/accentMain"
            android:textSize="17sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgAppearance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="System"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Light"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Dark"
                android:textColor="@color/textMain" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Accent theme"
            android:textColor="?attr/accentMain"
            android:textSize="17sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgAccent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbAqua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Aqua (teal / pink)"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbOcean"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ocean (blue / cyan)"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbGrape"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grape (purple / magenta)"
                android:textColor="@color/textMain" />

            <RadioButton
                android:id="@+id/rbEmber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ember (orange / red)"
                android:textColor="@color/textMain" />
        </RadioGroup>

    </LinearLayout>
</ScrollView>
